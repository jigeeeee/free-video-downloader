{
  "manifest_version": 3,
  "name": "Video Downloader Cookie Sync",
  "version": "1.1",
  "description": "Auto-sync browser cookies to video downloader",
  "permissions": ["cookies"],
  "host_permissions": [
    "*://*.bilibili.com/*",
    "*://*.douyin.com/*",
    "*://*.youtube.com/*",
    "*://*.tiktok.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost:5173/*", "http://127.0.0.1:8001/*"],
      "js": ["content.js"]
    }
  ]
}
