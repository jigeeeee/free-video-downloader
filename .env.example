# DeepSeek API Key (for AI features: video summary, subtitle translation, Q&A)
DEEPSEEK_API_KEY=sk-xxx

# Browser cookie source backup.
# Default empty = use QR/platform-synced cookies first, then generic cookies.txt.
# Options: chrome | edge | firefox | brave
# YTDLP_COOKIES_BROWSER=chrome

# Optional platform-specific Netscape cookie files.
# Normally generated automatically by chrome-extension.
# YTDLP_YOUTUBE_COOKIES_PATH=downloads/cookies/youtube.txt
# YTDLP_BILIBILI_COOKIES_PATH=downloads/cookies/bilibili.txt
# YTDLP_DOUYIN_COOKIES_PATH=downloads/cookies/douyin.txt

# Optional YouTube PO Token support for videos/CDNs that return 403.
# Format follows yt-dlp extractor args, for example: web.gvs+TOKEN_VALUE
# YTDLP_YOUTUBE_PO_TOKEN=web.gvs+TOKEN_VALUE
# YTDLP_YOUTUBE_VISITOR_DATA=VISITOR_DATA_VALUE

# Optional persistence / upload limits
# DB_PATH=downloads/video_downloader.db
# MAX_UPLOAD_MB=500

# Optional live regression test URLs. These are only used by pytest live tests.
# LIVE_YOUTUBE_URL=https://www.youtube.com/watch?v=...
# LIVE_BILIBILI_URL=https://www.bilibili.com/video/...
# LIVE_DOUYIN_URL=https://www.douyin.com/video/...
