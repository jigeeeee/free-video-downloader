# DeepSeek API Key (for AI features: video summary, subtitle translation, Q&A)
DEEPSEEK_API_KEY=sk-xxx

# Browser cookie source (default: chrome — auto-reads Chrome cookies, no export needed)
# Options: chrome | firefox | brave | "" (default: use QR/synced cookies, then cookies.txt)
# YTDLP_COOKIES_BROWSER=chrome

# Optional YouTube PO Token support for videos/CDNs that return 403.
# Format follows yt-dlp extractor args, for example: web.gvs+TOKEN_VALUE
# YTDLP_YOUTUBE_PO_TOKEN=web.gvs+TOKEN_VALUE
# YTDLP_YOUTUBE_VISITOR_DATA=VISITOR_DATA_VALUE

# Optional persistence / upload limits
# DB_PATH=downloads/video_downloader.db
# MAX_UPLOAD_MB=500
